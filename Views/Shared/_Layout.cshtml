@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Key Register Automation</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KEYREGISTERAUTOMATION.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />


    @RenderSection("Head", required: false)
</head>
<body class="@(currentController == "Account" ? "auth-page" : "")">

    <header class="app-header d-flex align-items-center px-4 justify-content-between">
        <div class="d-flex align-items-center">
            <img src="@Url.Content("~/images/picture.png")"
                 alt="Logo"
                 class="me-2"
                 style="height:32px; width:auto;" />
            <h5 class="mb-0 fw-semibold">Key Register Automation</h5>
        </div>

        @if (ViewBag.CurrentUserFullName != null)
        {
            <div class="text-end">
                <span class="fw-semibold">
                    <i class="bi bi-person-circle me-1"></i>
                    @ViewBag.CurrentUserFullName
                </span>
            </div>
        }
    </header>

    @if (currentAction == "Index" && (currentController == "Requester" || currentController == "FacilityManager" || currentController == "Administrator"))
    {
        <nav class="app-sidebar position-fixed start-0" aria-label="Primary navigation">
            <div class="app-sidebar-inner d-flex flex-column h-100">

                <ul class="nav flex-column pt-2">
                    @if (currentController == "Requester")
                    {
                        <li class="nav-item">
                            <button type="button" class="menu-link w-100">
                                <i class="bi bi-eye me-2"></i>
                                <span>Assignment Grid</span>
                            </button>
                        </li>

                    }
                    else if (currentController == "FacilityManager")
                    {

                        <li class="nav-item">
                            <button type="button" class="menu-link w-100" id="btnFMAllAssignments">
                                <i class="bi bi-eye me-2"></i>
                                <span>Assignment Grid</span>
                            </button>
                        </li>

                        <li class="nav-item">
                            <button type="button" class="menu-link w-100" id="btnAllKeys">
                                <i class="bi bi-key me-2"></i>
                                <span>Key Grid</span>
                            </button>
                        </li>


                        <li class="nav-item">
                            <button type="button" class="menu-link w-100" id="btnCreateAssignment">
                                <i class="bi bi-plus-square me-2"></i>
                                <span>Create Assignment</span>
                            </button>
                        </li>

                    }
                    else if (currentController == "Administrator")
                    {

                        <li class="nav-item">
                            <button type="button" class="menu-link w-100">
                                <i class="bi bi-eye me-2"></i>
                                <span>Assignment Grid</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="menu-link w-100">
                                <i class="bi bi-graph-up me-2"></i>
                                <span>Assignment Graph</span>
                            </button>
                        </li>
                    }
                </ul>
        </nav>
    }

    <div class="content-area"
         style="margin-left:@((currentAction == "Index" && (currentController == "Requester" || currentController == "FacilityManager" || currentController == "Administrator")) ? "var(--sidebar-width)" : "0"); padding-top: 70px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll(".menu-link").forEach(button => {
        button.addEventListener("click", function () {
        document.querySelectorAll(".menu-link").forEach(btn =>
        btn.classList.remove("active")
        );
        this.classList.add("active");
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
        window.onload = function () {
            if (sessionStorage.scrollTop) {
                window.scrollTo(0, sessionStorage.scrollTop);
            }
        };
        window.onbeforeunload = function () {
            sessionStorage.scrollTop = window.scrollY;
        };
    }
</script>